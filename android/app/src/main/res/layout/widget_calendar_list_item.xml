<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calendar_item_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/calendar_item_time"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:textColor="@color/quartzo_accent"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/calendar_item_checkbox"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="8dp"
        android:gravity="center"
        android:textColor="@color/quartzo_text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/calendar_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/quartzo_text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/calendar_item_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/quartzo_text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif" />
    </LinearLayout>
</LinearLayout>
