<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/filter_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="▼" android:textColor="#FFFFB300" android:textSize="18sp" />
        <TextView android:id="@+id/filter_title" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:text="Filtro" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:id="@+id/filter_menu" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="⋮" android:textSize="28sp" />
    </LinearLayout>

    <TextView android:id="@+id/filter_organizer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:ellipsize="end" android:maxLines="1" android:textSize="13sp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:layout_marginTop="18dp" android:orientation="horizontal">
        <TextView android:id="@+id/filter_chip_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:layout_weight="1" android:gravity="center" android:ellipsize="end" android:maxLines="1" android:textSize="14sp" />
        <TextView android:id="@+id/filter_chip_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:layout_weight="1" android:gravity="center" android:ellipsize="end" android:maxLines="1" android:textSize="14sp" />
        <TextView android:id="@+id/filter_chip_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:ellipsize="end" android:maxLines="1" android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout android:id="@+id/filter_progress_box" android:layout_width="match_parent" android:layout_height="62dp" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="14dp" android:paddingEnd="14dp">
        <TextView android:id="@+id/filter_progress_label" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Progresso" android:textSize="16sp" />
        <TextView android:id="@+id/filter_progress_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0/0" android:textSize="18sp" android:textStyle="bold" />
    </LinearLayout>

    <TextView android:id="@+id/filter_empty" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center" android:text="No items found." android:textSize="18sp" />

    <LinearLayout android:id="@+id/filter_row_0" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
        <TextView android:id="@+id/filter_type_0" android:layout_width="34dp" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:id="@+id/filter_item_0" style="@style/CitrineWidgetRowTitle" /><TextView android:id="@+id/filter_subtitle_0" style="@style/CitrineWidgetRowSubtitle" /></LinearLayout>
    </LinearLayout>
    <LinearLayout android:id="@+id/filter_row_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
        <TextView android:id="@+id/filter_type_1" android:layout_width="34dp" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:id="@+id/filter_item_1" style="@style/CitrineWidgetRowTitle" /><TextView android:id="@+id/filter_subtitle_1" style="@style/CitrineWidgetRowSubtitle" /></LinearLayout>
    </LinearLayout>
    <LinearLayout android:id="@+id/filter_row_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
        <TextView android:id="@+id/filter_type_2" android:layout_width="34dp" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:id="@+id/filter_item_2" style="@style/CitrineWidgetRowTitle" /><TextView android:id="@+id/filter_subtitle_2" style="@style/CitrineWidgetRowSubtitle" /></LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/filter_add_task" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="14dp" android:gravity="center" android:text="+  Adicionar tarefa" android:textSize="18sp" android:textStyle="bold" />
</LinearLayout>
