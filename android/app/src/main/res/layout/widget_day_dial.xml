<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/day_dial_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp"
    android:background="@color/quartzo_surface">

    <!-- Time Display -->
    <TextView
        android:id="@+id/day_dial_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12:00"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/quartzo_text_primary"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="4dp" />

    <!-- Date Display -->
    <TextView
        android:id="@+id/day_dial_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today"
        android:textSize="14sp"
        android:textColor="@color/quartzo_text_secondary"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="16dp" />

    <!-- Simple visual representation of day progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:orientation="horizontal"
        android:background="@color/quartzo_surface_variant">

        <View
            android:id="@+id/day_progress_bar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            android:background="@color/quartzo_accent" />

    </LinearLayout>

    <!-- Activity summary -->
    <TextView
        android:id="@+id/day_dial_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2 tasks • 1 event"
        android:textSize="12sp"
        android:textColor="@color/quartzo_text_secondary"
        android:fontFamily="sans-serif"
        android:layout_marginTop="12dp" />

</LinearLayout>
