<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/shopping_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/quartzo_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/shopping_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Lista de Mercado"
                android:textColor="@color/quartzo_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/shopping_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="0 pendentes"
                android:textColor="@color/quartzo_text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/shopping_sync_btn"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="↻"
                android:textColor="@color/quartzo_text_secondary"
                android:textSize="18sp"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/shopping_add_btn"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/quartzo_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/shopping_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" />

</LinearLayout>
